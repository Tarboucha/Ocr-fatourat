# --- Postgres ---
POSTGRES_USER=ocr
POSTGRES_PASSWORD=ocr
POSTGRES_DB=ocr

# --- Backend ---
# Async SQLAlchemy URL. Host "db" matches the docker-compose service name.
DATABASE_URL=postgresql+asyncpg://ocr:ocr@db:5432/ocr
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=/data/uploads
# Comma-separated list of allowed CORS origins (frontend dev server)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- OCR / async jobs ---
REDIS_URL=redis://redis:6379/0
# Which OCR pipeline runs by default: rapidocr | tesseract | paddle | stub
DEFAULT_OCR_PIPELINE=rapidocr

# --- Frontend ---
# Base URL the browser uses to reach the API (proxied by Vite in dev)
VITE_API_BASE=/api/v1
